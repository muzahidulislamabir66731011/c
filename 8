#include <stdio.h>
int main()
{
    int c;
    int freq[128] = {0};
    int i, j;
    while ((c = getchar()) != EOF) {
        if (c >= 0 && c < 128) {
            freq[c]++;
        }
    }
    printf("Character Frequency Histogram:\n");
    printf("=============================\n");
    for (i = 0; i < 128; i++) {
        if (freq[i] > 0) {
            if (i >= 32 && i < 127) {
                printf("'%c' : ", i);
            } else {
                printf("%3d : ", i);
            }
            
            // Print # for each occurrence
            for (j = 0; j < freq[i]; j++) {
                printf("#");
            }
            printf("\n");
        }
    }
    return 0;
}
