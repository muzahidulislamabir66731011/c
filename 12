#include <stdio.h>

#define MAXLINE 4

int get_line(char line[], int lim);
void copy(char to[], char from[]);

int main()
{
    int len;
    int max = 0;

    char line[MAXLINE];
    char longest[MAXLINE];

    while ((len = get_line(line, MAXLINE)) > 0) {

        if (len > max) {
            max = len;
            copy(longest, line);
        }
    }

    if (max > 0) {
        printf("Longest length: %d\n", max);
        printf("Longest line (partial):\n%s", longest);
    }
    return 0;
}

int get_line(char s[], int lim)
{
    int c, i;
    int len = 0;

    for (i = 0; i < lim - 1; i++) {
        c = getchar();

        if (c == EOF)
            break;

        if (c == '\n') {
            s[i] = c;
            len++;
            i++;
            break;
        }

        s[i] = c;
        len++;
    }

    s[i] = '\0';

    while (c != '\n' && c != EOF) {
        c = getchar();
        len++;
    }
    return len;
}

void copy(char to[], char from[])
{
    int i;
    i = 0;
    while ((to[i] = from[i]) != '\0')
        ++i;
}
