#include <stdio.h>

int my_islower(char c) {
    return (c >= 'a' && c <= 'z');
}

int my_isupper(char c) {
    return (c >= 'A' && c <= 'Z');
}

int my_isdigit(char c) {
    return (c >= '0' && c <= '9');
}

void expand(char s1[], char s2[]) {
    int i, j, k;

    for (i = 0, j = 0; s1[i] != '\0'; i++) {
        if (s1[i] == '-' && i > 0 && s1[i+1] != '\0' && s1[i-1] <= s1[i+1] &&
            ((my_islower(s1[i-1]) && my_islower(s1[i+1])) ||
             (my_isupper(s1[i-1]) && my_isupper(s1[i+1])) ||
             (my_isdigit(s1[i-1]) && my_isdigit(s1[i+1])))) {

            for (k = s1[i-1] + 1; k <= s1[i+1]; k++)
                s2[j++] = k;
        } else {
            s2[j++] = s1[i];
        }
    }
    s2[j] = '\0';
}

int main() {
    char s1[] = "a-z0-9-A-Z-a-b-c-";
    char s2[200];

    expand(s1, s2);

    printf("%s\n", s2);
    return 0;
}
