#include <stdio.h>

void reverse(char s[])
{
    int i = 0, j = 0;
    char c;

    while (s[j] != '\0')
        j++;
    j--;

    while (i < j) {
        c = s[i];
        s[i] = s[j];
        s[j] = c;
        i++;
        j--;
    }
}

void itob(int n, char s[], int b)
{
    int i = 0, sign;
    unsigned int x = n;
    const char digits[] = "0123456789ABCDEF";

    if (b < 2 || b > 16) {
        s[0] = '\0';
        return;
    }

    sign = n;

    if (n < 0)
        x = -n;

    do {
        s[i++] = digits[x % b];
    } while ((x /= b) > 0);

    if (sign < 0)
        s[i++] = '-';

    s[i] = '\0';

    reverse(s);
}

int main()
{
    char s[100];

    int n = 255;

    itob(n, s, 16);
    printf("Decimal: %d -> Hex: %s\n", n, s);

    itob(n, s, 2);
    printf("Decimal: %d -> Binary: %s\n", n, s);

    itob(n, s, 8);
    printf("Decimal: %d -> Octal: %s\n", n, s);

    int m = -42;
    itob(m, s, 16);
    printf("Decimal: %d -> Hex: %s\n", m, s);

    return 0;
}
