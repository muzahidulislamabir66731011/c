int binsearch(int x, int v[], int n)
{
    int low = 0;
    int high = n - 1;

    while (low <= high) {  // Is there still a valid search range? we still check that last element
        int mid = (low + high) / 2;

        if (x < v[mid])
            high = mid - 1;
        else if (x > v[mid])
            low = mid + 1;
        else
            return mid; 
    }

    return -1;  
}
