#include <stdio.h>

int any(char s1[], char s2[])
{
    int lookup[256] = {0};

    for (int i = 0; s2[i] != '\0'; i++) {
        lookup[(unsigned char)s2[i]] = 1;
    }

    for (int i = 0; s1[i] != '\0'; i++) {
        if (lookup[(unsigned char)s1[i]]) {
            return i;
        }
    }

    return -1;
}
