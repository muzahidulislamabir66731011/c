#include <stdio.h>
void shellsort( int v[] , int n){
    int i = 0;
    int j = 0;
    int gap;
    int temp;
    for (gap =n/2; gap > 0; gap /= 2)
    {
        for ( i = gap; i < n; i++)
        {
            for ( j = i - gap; j >= 0 && v[j] > v[j+gap] ; j -= gap)
            {
                temp = v[j];
                v[j] = v[j+gap];
                v[j+gap] = temp;
            }
        }
    }
    
}
int main(){
    int v[] ={ 8, 5, 3 , 1};
    int n = 4;
    shellsort(v , n);
    for (int i = 0; i < n; i++)
    {
        printf("%d" , v[i]);
    }

    return 0;
    
}
