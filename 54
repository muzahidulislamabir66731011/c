#include <stdio.h>
#include <string.h>

void reverse(char s[])
{
    int i, j;
    char c;

    for (i = 0, j = strlen(s) - 1; i < j; i++, j--) {
        c = s[i];
        s[i] = s[j];
        s[j] = c;
    }
}

void itoa(int n, char s[], int w)
{
    int i = 0, sign = n;

    do {
        int digit = n % 10;
        if (digit < 0)
            digit = -digit;
        s[i++] = digit + '0';
    } while ((n /= 10) != 0);

    if (sign < 0)
        s[i++] = '-';

    while (i < w)
        s[i++] = ' ';

    s[i] = '\0';

    reverse(s);
}

int main(void)
{
    char buffer[100];

    itoa(42, buffer, 5);
    printf("'%s'\n", buffer);

    itoa(-7, buffer, 5);
    printf("'%s'\n", buffer);

    itoa(12345, buffer, 3);
    printf("'%s'\n", buffer);

    return 0;
}
